# ============================
# SERVER CONFIGURATION
# ============================
NODE_ENV=development
PORT=5000

# ============================
# DATABASE
# ============================
MONGO_URI=mongodb://localhost:27017/sareebazaar
# OR Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/sareebazaar

# ============================
# JWT SECRETS
# ============================
JWT_SECRET=sareebazaar_jwt_secret_change_this_in_production_32chars
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=sareebazaar_refresh_secret_change_this_in_production
JWT_REFRESH_EXPIRE=7d

# ============================
# COOKIE
# ============================
COOKIE_EXPIRE_DAYS=7

# ============================
# CLIENT URL (for CORS)
# ============================
CLIENT_URL=http://localhost:3000

# ============================
# EMAIL (SMTP)
# ============================
# Gmail setup:
# 1. Enable 2-Step Verification at myaccount.google.com/security
# 2. Go to myaccount.google.com/apppasswords
# 3. Select "Mail" → Generate → copy the 16-char password (remove spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_gmail@gmail.com              # your actual gmail address
SMTP_PASSWORD=abcdabcdabcdabcd              # 16-char app password, no spaces
FROM_NAME=SareeBazaar
FROM_EMAIL=your_gmail@gmail.com              # same as SMTP_EMAIL

# ============================
# CLOUDINARY (Image Storage)
# ============================
# Sign up free at cloudinary.com → Dashboard → copy the 3 values below
CLOUDINARY_CLOUD_NAME=your_cloud_name        # e.g. dxyz12abc
CLOUDINARY_API_KEY=your_api_key              # e.g. 123456789012345
CLOUDINARY_API_SECRET=your_api_secret        # e.g. abcDEFghiJKLmnoPQR

# ============================
# RAZORPAY PAYMENT GATEWAY
# ============================
# Sign up at razorpay.com → Settings → API Keys → Generate Test Key
# Test Key ID starts with rzp_test_
# Switch to rzp_live_ keys only when going live
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx        # from Razorpay dashboard
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx     # from Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=sareebazaar_webhook_secret_change_this  # any string you choose

# ============================
# TWILIO (SMS / OTP)
# ============================
TWILIO_ACCOUNT_SID=REPLACE_WITH_YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ============================
# SHIPROCKET LOGISTICS
# ============================
SHIPROCKET_EMAIL=REPLACE_WITH_YOUR_SHIPROCKET_EMAIL
SHIPROCKET_PASSWORD=REPLACE_WITH_YOUR_SHIPROCKET_PASSWORD
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external

# ============================
# GOOGLE OAUTH (optional)
# ============================
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ============================
# SESSION SECRET (for passport)
# ============================
SESSION_SECRET=REPLACE_WITH_SESSION_SECRET

# ============================
# RATE LIMITING
# ============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================
# VENDOR COMMISSION
# ============================
PLATFORM_COMMISSION_PERCENT=10
